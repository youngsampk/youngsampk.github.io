@article{singwangyeongSegyehwaSidaeGyegeubrongwa2008,
  title = {{세계화 시대 계급론과 계급 분석}},
  author = {신광영},
  year = 2008,
  month = mar,
  journal = {경제와사회},
  pages = {238--255},
  issn = {1227-1373},
  urldate = {2024-04-13},
  abstract = {이 논문은 계급(론)과 계급 분석에 관한 기존의 입장을 정리하고 세계화 시대에 필요한 계급 분석에 대해서 논의한다. 계급이론은 계급 분석의 이론적인 토대를 제공했으며, 계급이론은 사회 불평등을 설명하는 하나의 과학적 연구프로그램으로 발전해왔음을 논의한다. 그리고 라카토스의 과학 개념에 기초하여 아직도 사회 불평등 설명에서 계급이론의 설명력을 능가하는 사회과학 이론이 없다는 점에서 과학적인 이론의 역할을 하고 있다. 그렇지만 국민국가를 분석단위로 하는 기존의 계급 분석이 세계화로 인하여 발생하는 국내적 변화와 지구적 변화에 따른 계급관계와 계급정치의 지리적 탈구현상을 포작하기 힘들다는 점을 지적한다. 세계화에 따른 새로운 계급 불평등과 계급역학을 분석하기 위해서 통합적인 계급 분석이 필요함을 논의한다.},
  langid = {korean},
  keywords = {,(),(research program),class,class analysis,class inequality,class politics,dislocation,globalization,Lakatos,notion,scientific research program},
  file = {K:\내 드라이브\00PhD\경제와사회2008\신광영_2008_세계화 시대 계급론과 계급 분석2.pdf}
}

