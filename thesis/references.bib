@article{guhaegeun2007,
  title = {{세계화 시대의 한국 계급 연구를 위한 이론적 모색}},
  author = {구해근},
  year = 2007,
  month = dec,
  journal = {경제와사회},
  pages = {255--289},
  issn = {1227-1373},
  urldate = {2025-10-11},
  abstract = {이 논문의 목적은 현재 한국 사회에 새로 형성되고 있는 계급 구조와 계급 역학을 적절하게 분석할 수 있는 새로운 계급 분석 틀을 모색하는 데 있다. 그러기 위해서 이 논문은 우선 최근 서구의 계급이론 동향을 검토한 후 그를 바탕으로 한국의 계급 현상을 체계적으로 연구하기 위해 구조적인 접근과 과정적인 접근을 같이 해야 할 것을 강조한다. 계급을 구조적으로 분석하는 데 있어서 이 논문은 계급 위치를 개인이 소유한 자원의 앙과 종류로 접근하는 베버와 부르디외적 방법과 이런 자원의 분배와 힘(power)의 관계를 정치경제학적 맥락에서 접근하는 마르크스적 이론을 통합하는 접근방법을 제시한다. 그 다음 논문의 초점은 세계화 과정이 어떻게 한국의 계급 구조와 계급 행위에 영향을 미치는가에 맞추어져 있다. 급속도로 세계화하고 있는 한국 사회에서 계급 구조에 나타나는 가장 중요한 변화는 계급의 분절화와 재구성이다. 계급의 분절화는 상류계급, 중간계급, 노동자 계급의 3대 계급 내에 생기는 내부 분화를 의미한다. 그리고 계급 재구성은 이렇게 분절화한 계급 집단 또는 계급 분파가 세계화 과정 속에서 계급적 프리빌리지(privilege)를 가진 집단과 갖지 못한 집단으로 양분되며 그 두 집단 간에 사회적ㆍ문화적 차이가 날로 확대되는 추세를 의미한다. 세계화는 계급 행위와 계급전략이 행해지는 장과 기회 구조를 확대하고 그에 따라서 계급의 불평등을 심화시키고 재생산시키는 기제로 작용한다. 마지막으로 이 논문은 현재 한국 사회에서 논쟁거리인 사회 양극화와 중산층 몰락 문제를 다룬다. 이 논문의 주장은 한국의 중산층은 단순히 몰락했거나 현상유지되고 있다기보다 내부 분화를 통해 그 사회적 존재가 심각하게 변형되는 과정을 겪고 있다는 것이다. 중산층이 내부 분화를 하면서 과거와 다른 형태의 이질성이 증대되었고 사회적 상승 이동보다는 하향 이동의 위험성이 높아짐으로써 과거의 사회통합적ㆍ사회계약적 기능을 잃게 되었다는 것이다.},
  langid = {korean},
  file = {D:\00PhD\storage\E9KZLYMU\구해근 - 2007 - 세계화 시대의 한국 계급 연구를 위한 이론적 모색.pdf}
}

@article{gweonhyeonji2015,
  title = {{저임금 서비스 노동시장의 젠더 불평등}},
  author = {권현지 and 김영미 and 권혜원},
  year = 2015,
  month = sep,
  journal = {경제와사회},
  volume = {107},
  pages = {44--78},
  issn = {1227-1373},
  urldate = {2025-10-26},
  abstract = {이 연구는 서비스경제화의 과정에서 확대되고 있는 여성의 일자리가 주로 저임금부문에 집중되어 불평등한 상태로 유지{$\cdot$}강화되는 현재의 노동시장 현상에 주목하고, 이에 대해 분석틀을 마련하려는 시도다. 견고하게 지속되고 있는 서비스 경제하 여성노동의 저임금화와 불평등의 유지를 틸리(C. Tilly)의 장기지속 불평등이라는 개념틀을 차용해 이해해 보려고 하였다. 즉, 노동조직내부의 경계와 사회규범이 배태된 사회적 범주의 차이가 결합되어 시장 합리성의 논리로는 설명되기 어려운 젠더 불평등이 견고하게 유지되는 과정을 설명하였다. 또 이러한 불평등을 생성하고 유지시키는 주요 행위자로 기업에 주목하고, 기업 구조와 정책이 이 과정에 어떻게 작용하는지를 논의하였다. 구체적으로, (1) 기업내 성분절적 고용관리 정책, (2) 기업 간 전근대적 위계 분업 관계, (3) 신분제적 고객관계를 강화하는 대고객서비스 전략이 어떻게 사회적 위계로서의 젠더 범주와 결합되고 상호작용함으로써 여성서비스노동자의 불평등한 노동경험을 유지 강화하는지 그 메커니즘을 설명하였다.},
  langid = {korean},
  keywords = {,customer sovereignty,durable inequality. low wages,employment practices,feudal customer relations,gender,hierarchical production networks,labor,outsourcing,segmentation,service economy},
  file = {D:\00PhD\storage\7QB7GDEK\권현지 등 - 2015 - 저임금 서비스 노동시장의 젠더 불평등.pdf}
}

@article{gyebongo2016,
  title = {{한국의 세대간 사회이동 : 출생 코호트 및 성별 비교}},
  shorttitle = {{한국의 세대간 사회이동}},
  author = {계봉오 and 황선재},
  year = 2016,
  month = sep,
  journal = {한국인구학},
  volume = {39},
  number = {3},
  pages = {1--28},
  issn = {1226-2986},
  urldate = {2025-11-09},
  abstract = {이 연구는 한국의 세대간 사회이동 변화를 출생 코호트와 성별 비교를 통해 경험적으로 검토한다. 기존의 연구에 따르면 대부분의 산업사회에서 절대적 사회이동(absolute mobility)은 증가하다가 최근 들어 감소하는 경향을 보여주지만, 상대적 사회이동(relative mobility)에는 뚜렷한 패턴이 발견되지 않는다. 즉, 직업구조 변화에 따라 구조적 이동(structural mobility)의 양상은 변화하지만, 세대간 유동성(fluidity)에는 큰 변화가 없다는 것이다. 한국사회의 경우 급격한 산업구조 변동으로 인해 절대적 이동이 다른 국가들보다 높은 수준이며, 상대적 이동 또한 다소 높은 것으로 나타난다. 그러나 최근 들어 한국사회에서는 ``수저계급론'' 등 계층구조의 고착화에 대한 사회적 우려가 증가하고 있으며, 이는 계층갈등의 심화 및 사회적 신뢰수준의 저하로 연결되고 있다. 이러한 현상은 산업화가 일정 단계를 넘어서면 사회적 유동성이 오히려 감소할 수 있다는 ``후기산업사회 경직화 가설(post-industrial rigidification thesis)''의 주장과 일맥상통한다. 이 연구는 절대적 이동과 상대적 이동이 사회이동 연구에서 갖는 함의를 고찰하고, 한국교육개발원의 ``교육과 사회이동 조사연구''를 사용하여 세대간 사회이동 패턴의 출생 코호트별, 성별 변화를 살펴본다. 분석결과에 따르면 최근 코호트의 절대적 이동은 다소 감소한 반면, 상대적 이동은 크게 변화하지 않았다. 또한 통계적으로 유의하지는 않지만, 남성의 유동성은 다소 증가했으나 여성의 경우에는 감소하고 있다. 이는 사회적 유동성의 변화와 계층구조 경직성에 대한 인식이 일치하지 않을 수 있으며. 수저계급론 등과 같은 사회적 폐쇄(social closure)의 강화라는 단순한 개념으로는 사회이동의 패턴 및 계층구조 인식의 변화를 설명할 수 없음을 보여준다.},
  langid = {korean},
  file = {D:\00PhD\storage\XPD28THI\계봉오 및 황선재 - 2016 - 한국의 세대간 사회이동  출생 코호트 및 성별 비교.pdf}
}

@article{haas2024,
  title = {Social {{Inequalities}} in {{Study Trajectories}}: {{A Comparison}} of the {{United States}} and {{Germany}}},
  shorttitle = {Social {{Inequalities}} in {{Study Trajectories}}},
  author = {Haas, Christina and Hadjar, Andreas},
  year = 2024,
  month = jul,
  journal = {Sociology of Education},
  volume = {97},
  number = {3},
  pages = {276--296},
  publisher = {SAGE Publications Inc},
  issn = {0038-0407},
  doi = {10.1177/00380407241228553},
  urldate = {2025-11-01},
  abstract = {Social origin affects not only access to higher education but also how students proceed through higher education. Based on the argument that an advantageous family background facilitates linear study trajectories through parents' provision of cultural and economic resources, this article investigates study trajectories in Germany and the United States, assessing the institutional structures as an intermediating factor. We reconstruct study trajectories of bachelor-degree-seeking students using sequence analysis based on two high-quality panel data sets (U.S. Beginning Postsecondary Students Longitudinal Study and the German National Educational Panel Study). The findings reveal that study trajectories are more complex overall and shaped by social origin in the United States. In both countries, study trajectories differ by higher education institution type. We conclude that not only are access pathways to higher education shaped by the institutional context of higher education systems but also that study trajectories and the disparities structured by socioeconomic background are equally institutionally embedded.},
  langid = {english},
  file = {D:\00PhD\storage\YDSK3C8R\Haas 및 Hadjar - 2024 - Social Inequalities in Study Trajectories A Comparison of the United States and Germany.pdf}
}

