@article{singwangyeong2013,
  title = {{2000년대 계급/계층 연구의 현황과 과제}},
  author = {신광영},
  year = 2013,
  month = dec,
  journal = {경제와사회},
  volume = {100},
  pages = {114--137},
  issn = {1227-1373},
  urldate = {2025-09-12},
  abstract = {이 논문은 외환위기 이후 2000년대 한국에서 이루어진 계급과 계층 연구를 검토하여, 이들 연구를 통해서 밝혀진 연구 성과를 분석하고 그리고 향후 한국의 계급과 계층 연구의 과제를 도출한다. 외환위기 이후 계급 연구가 크게 활성화되면서 여러 영역에서 계급 연구 성과가 만들어졌다. 외환위기 이후의 계급연구는 신자유주의적 세계화의 영향에 따른 국내외 계급에 대한 경험적 연구로 확대되었다. 계급 불평등, 불안전 고용, 계급문화, 계급의식 등에 대한 연구가 크게 진전이 되었고, 세계화가 진전되면서, 해외 지역의 계급 연구도 이루어졌다. 이러한 연구를 통하여 국내외 불평등과 계급/계층 현상에 대한 깊이 있는 이해가 이루어졌다. 마지막으로 이 논문은 2000년대 계급/계층 연구가 다루어야 할 과제로 계급 연구의 불균형을 시정하는 연구와 계급과 정치의 탈구 현상에 관한 연구를 논의한다.},
  langid = {korean},
  file = {D:\00PhD\storage\KFM6WDSG\신광영 - 2013 - 2000년대 계급계층 연구의 현황과 과제.pdf}
}

