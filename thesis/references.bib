  shorttitle = {{한국의 국가공공성 형성과 구조}},
  author = {김원섭 and 김수한},
  year = 2013,
  month = jun,
  journal = {아세아연구},
  volume = {56},
  number = {2},
  pages = {42--74},
  issn = {1226-4385},
  urldate = {2025-10-26},
  abstract = {This paper shows the characteristics and formation of publicness in Korea by examining the state publicness in the period of developmental state. State was strong and civic society was weak in developmental state; this historical context made state publicness dominate in Korean society. The characteristics of state publicness differed from those of publicness in developed Western countries in three ways: public citizenship, pubic openness, and public interest. First, public citizenship was limited since the state prohibited Korean citizens from suggesting and forming public social agenda. Second, public openness was nearly closed since the equality discourse that might conflict with the logic of development discourse was oppressed and disallowed. Third, public interest was subject to state policy since the social policy was made to serve the goals of economic development and those of national security.},
  langid = {korean}
}

