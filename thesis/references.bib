@article{karabarbounis2014,
  title = {The {{Global Decline}} of the {{Labor Share}}*},
  author = {Karabarbounis, Loukas and Neiman, Brent},
  year = 2014,
  month = feb,
  journal = {The Quarterly Journal of Economics},
  volume = {129},
  number = {1},
  pages = {61--103},
  issn = {0033-5533},
  doi = {10.1093/qje/qjt032},
  urldate = {2025-06-01},
  abstract = {The stability of the labor share of income is a key foundation in macroeconomic models. We document, however, that the global labor share has significantly declined since the early 1980s, with the decline occurring within the large majority of countries and industries. We show that the decrease in the relative price of investment goods, often attributed to advances in information technology and the computer age, induced firms to shift away from labor and toward capital. The lower price of investment goods explains roughly half of the observed decline in the labor share, even when we allow for other mechanisms influencing factor shares, such as increasing profits, capital-augmenting technology growth, and the changing skill composition of the labor force. We highlight the implications of this explanation for welfare and macroeconomic dynamics.},
  file = {K:\내 드라이브\00PhD\The Quarterly Journal of Economics2014\Karabarbounis_Neiman_2014_The Global Decline of the Labor Share.pdf}
}

@misc{karabarbounis2014a,
  type = {Working {{Paper}}},
  title = {Capital {{Depreciation}} and {{Labor Shares Around}} the {{World}}: {{Measurement}} and {{Implications}}},
  shorttitle = {Capital {{Depreciation}} and {{Labor Shares Around}} the {{World}}},
  author = {Karabarbounis, Loukas and Neiman, Brent},
  year = 2014,
  month = oct,
  series = {Working {{Paper Series}}},
  number = {20606},
  eprint = {20606},
  publisher = {National Bureau of Economic Research},
  doi = {10.3386/w20606},
  urldate = {2025-08-26},
  abstract = {The labor share is typically measured as compensation to labor relative to gross value added ("gross labor share"), in part because gross value added is more directly measured than net value added. Labor compensation relative to net value added ("net labor share") may be more important in some settings, however, because depreciation is not consumed. In this paper we make three contributions. First, we document that gross and net labor shares generally declined together in most countries around the world over the past four decades. Second, we use a simple economic environment to show that declines in the price of capital necessarily cause gross and net labor shares to move in the same direction, whereas other shocks such as a decline in the real interest rate may cause the net labor share to rise when the gross labor share falls. Third, we illustrate that whether the gross or the net labor share is a more useful proxy for inequality during an economy's transition depends sensitively on the nature of the underlying shocks that hit the economy.},
  archiveprefix = {National Bureau of Economic Research},
  file = {K:\내 드라이브\00PhD\National Bureau of Economic Research2014\Karabarbounis_Neiman_2014_Capital Depreciation and Labor Shares Around the World.pdf}
}

