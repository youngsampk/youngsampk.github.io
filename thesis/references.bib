@article{connelly2021,
  title = {Social Class Inequalities in Educational Attainment: Measuring Social Class Using Capitals, Assets and Resources},
  shorttitle = {Social Class Inequalities in Educational Attainment},
  author = {Connelly, Roxanne and Gayle, Vernon and Playford, Chris},
